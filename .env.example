# ── LLM provider keys ──────────────────────────────────────────────────────
# At least one key must match OPENCLAW_AGENT_MODEL's provider. For free-tier
# dev, a Google AI Studio key (GOOGLE_API_KEY) plus the default Gemini model
# is enough to handle inbound channel messages.
#
# The context-agent's internal extract/consolidation/render calls go to
# Anthropic directly (not via OpenClaw's provider router) — set
# ANTHROPIC_API_KEY if you want those to work.
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

VOYAGE_API_KEY=sk-voyage-YOUR_KEY_HERE
# Embedding model config (defaults shown; override to switch provider/dims)
WHATSON_EMBEDDING_MODEL=voyage-3-lite
WHATSON_EMBEDDING_DIMS=512

OPENCLAW_GATEWAY_TOKEN=context-agent-dev-token-change-me
OPENCLAW_GATEWAY_PORT=18789
# OpenClaw native agent model — handles inbound channel messages and MCP
# tool calls. Format: "provider/model". Default uses Google's free tier.
# Alternatives: anthropic/claude-haiku-4-5, groq/llama-3.3-70b-versatile.
OPENCLAW_AGENT_MODEL=google/gemini-2.0-flash

TELEGRAM_BOT_TOKEN=123456:ABCDEF_YOUR_TOKEN

# Slack channel (optional). Socket mode: set SLACK_BOT_TOKEN + SLACK_APP_TOKEN.
# HTTP mode: set SLACK_BOT_TOKEN + SLACK_SIGNING_SECRET.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# Microsoft Teams channel (optional). All three required to enable.
MSTEAMS_APP_ID=
MSTEAMS_APP_PASSWORD=
MSTEAMS_TENANT_ID=

# Target repo integration (optional)
# If unset, consolidation runs locally only and sync_repo returns skipped.
TARGET_REPO=https://github.com/yourusername/yourrepo.git
WHATSON_CONTEXT_DIR=docs/context
# GITHUB_TOKEN is injected into https:// URLs for auth. Omit for ssh URLs.
GITHUB_TOKEN=
WHATSON_COMMIT_AUTHOR=Whatson <whatson@bot.local>
# Set to "false" to commit locally without pushing.
WHATSON_SYNC_PUSH=true
# Auto-sync gate on consolidation:
#   0   → never auto-sync (use /sync manually)
#   1   → sync after every consolidation (default)
#   N>1 → sync after every Nth consolidation
WHATSON_SYNC_EVERY_N_CONSOLIDATION=1
WHATSON_DRIFT_ENABLED=true

# Audit pass — self-reflection on facts (optional)
# When enabled, after each consolidation run, the agent audits recent facts
# and asks itself: what gaps, contradictions, or follow-up questions did I miss?
# Results are stored as question-type facts and merged into heartbeat findings.
WHATSON_AUDIT_ENABLED=false
# How many of the most-recent facts to audit each run (default 50).
WHATSON_AUDIT_LOOKBACK=50
