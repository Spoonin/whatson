ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
VOYAGE_API_KEY=sk-voyage-YOUR_KEY_HERE
# Embedding model config (defaults shown; override to switch provider/dims)
WHATSON_EMBEDDING_MODEL=voyage-3-lite
WHATSON_EMBEDDING_DIMS=512
OPENCLAW_GATEWAY_TOKEN=context-agent-dev-token-change-me
OPENCLAW_GATEWAY_PORT=18789
# OpenClaw native agent model (handles inbound channel messages and MCP tool
# calls). Format: "provider/model". Haiku keeps API bills low; swap to
# anthropic/claude-sonnet-4-6 if you need stronger reasoning.
OPENCLAW_AGENT_MODEL=anthropic/claude-haiku-4-5
TELEGRAM_BOT_TOKEN=123456:ABCDEF_YOUR_TOKEN

# Slack channel (optional). Socket mode: set SLACK_BOT_TOKEN + SLACK_APP_TOKEN.
# HTTP mode: set SLACK_BOT_TOKEN + SLACK_SIGNING_SECRET.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# Microsoft Teams channel (optional). All three required to enable.
MSTEAMS_APP_ID=
MSTEAMS_APP_PASSWORD=
MSTEAMS_TENANT_ID=

# Target repo integration (optional)
# If unset, consolidation runs locally only and sync_repo returns skipped.
TARGET_REPO=https://github.com/yourusername/yourrepo.git
WHATSON_CONTEXT_DIR=docs/context
# GITHUB_TOKEN is injected into https:// URLs for auth. Omit for ssh URLs.
GITHUB_TOKEN=
WHATSON_COMMIT_AUTHOR=Whatson <whatson@bot.local>
# Set to "false" to commit locally without pushing.
WHATSON_SYNC_PUSH=true
# Auto-sync gate on consolidation:
#   0   → never auto-sync (use /sync manually)
#   1   → sync after every consolidation (default)
#   N>1 → sync after every Nth consolidation
WHATSON_SYNC_EVERY_N_CONSOLIDATION=1
WHATSON_DRIFT_ENABLED=true